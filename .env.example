# Listless configuration
# Copy to .env and fill in values

# SQLite database path
# In Docker (default): sqlite:////app/data/listless.db
# Local development:   sqlite:///listless.db
LISTLESS_DATABASE_URL=sqlite+aiosqlite:////app/data/listless.db

# TMDb API key – required for IMDb↔TMDb↔TVDb ID resolution
LISTLESS_TMDB_API_KEY=

# TMDb API base URL (default: https://api.themoviedb.org/3)
# LISTLESS_TMDB_API_BASE=https://api.themoviedb.org/3

# Default HTTP timeout in seconds (default: 20.0)
# LISTLESS_DEFAULT_HTTP_TIMEOUT=20.0
